# ============================================================================
# DARI FOR BUSINESS - Multi-Chain Stablecoin Payment Gateway
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite for development (default)
DATABASE_URL=sqlite:///./dari_payments.db

# PostgreSQL for production (recommended)
# DATABASE_URL=postgresql://user:password@localhost:5432/dari_payments

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT Secret - MUST be changed in production (minimum 32 characters)
JWT_SECRET=your-secret-key-change-this-in-production-minimum-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API Key Signing Secret - For merchant API keys
API_KEY_SECRET=your-api-key-secret-change-in-production

# PII Encryption Key (GDPR compliance - Fernet symmetric key)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=

# ============================================================================
# GOOGLE OAUTH (ONBOARDING)
# ============================================================================
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# For production, update GOOGLE_REDIRECT_URI to your production domain
# GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# ============================================================================
# STELLAR BLOCKCHAIN
# ============================================================================
STELLAR_ENABLED=true
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Mainnet configuration:
# STELLAR_NETWORK=public
# STELLAR_HORIZON_URL=https://horizon.stellar.org

# USDC Asset on Stellar
USDC_ASSET_CODE=USDC
USDC_ASSET_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ============================================================================
# ETHEREUM MAINNET
# ============================================================================
ETHEREUM_ENABLED=true
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
ETHEREUM_CHAIN_ID=1

# Token Contract Addresses on Ethereum
ETHEREUM_USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
ETHEREUM_USDT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
ETHEREUM_PYUSD_ADDRESS=0x6c3ea9036406852006290770BEdFcAbA0e23A0e8

# Confirmations required for Ethereum
ETHEREUM_CONFIRMATIONS=12

# ============================================================================
# POLYGON MAINNET
# ============================================================================
POLYGON_ENABLED=true
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
POLYGON_CHAIN_ID=137

# Token Contract Addresses on Polygon
POLYGON_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
POLYGON_USDT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F

# Confirmations required for Polygon
POLYGON_CONFIRMATIONS=128

# ============================================================================
# BASE MAINNET
# ============================================================================
BASE_ENABLED=true
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453

# Token Contract Addresses on Base
BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Confirmations required for Base
BASE_CONFIRMATIONS=10

# ============================================================================
# TRON MAINNET
# ============================================================================
TRON_ENABLED=true
TRON_API_URL=https://api.trongrid.io
TRON_API_KEY=your-trongrid-api-key-here

# Token Contract Addresses on Tron
TRON_USDT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_USDC_ADDRESS=TEkxiTehnzSmSe2XqrBj4w32RUN966rdz8

# ============================================================================
# SOLANA
# ============================================================================
SOLANA_ENABLED=false
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
SOLANA_USDT_MINT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB

# ============================================================================
# SOROBAN (STELLAR SMART CONTRACTS)
# ============================================================================
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ============================================================================
# WEB3 SUBSCRIPTIONS
# ============================================================================

# --- EVM Gasless Relayer ---
# Relayer wallet private key (0x-prefixed hex)
RELAYER_PRIVATE_KEY=
RELAYER_MAX_GAS_PRICE_GWEI=100

# Deployed EVM subscription contracts (fill after deployment)
SUBSCRIPTION_CONTRACT_ETHEREUM=
SUBSCRIPTION_CONTRACT_POLYGON=
SUBSCRIPTION_CONTRACT_BASE=
SUBSCRIPTION_CONTRACT_BSC=
SUBSCRIPTION_CONTRACT_ARBITRUM=
SUBSCRIPTION_CONTRACT_AVALANCHE=

# --- Tron Subscription Relayer ---
# Private key for Tron relayer wallet (hex-encoded, no 0x prefix)
TRON_RELAYER_PRIVATE_KEY=
# Deployed DariSubscriptionsTron contract (base58)
SUBSCRIPTION_CONTRACT_TRON=

# --- Solana Subscription Relayer ---
# 64-byte keypair as hex (use: solana-keygen new, then convert to hex)
SOLANA_RELAYER_PRIVATE_KEY=
# Deployed Anchor program ID (base58)
SUBSCRIPTION_PROGRAM_SOLANA=

# --- Soroban (Stellar) Subscription Relayer ---
# Stellar secret key (starts with S...)
SOROBAN_RELAYER_SECRET_KEY=
# Deployed Soroban contract ID
SUBSCRIPTION_CONTRACT_SOROBAN=

# --- Scheduler Settings ---
SCHEDULER_INTERVAL_SECONDS=60
SCHEDULER_BATCH_SIZE=100
SCHEDULER_MAX_RETRIES=6
SCHEDULER_RETRY_INTERVAL_HOURS=12

# Enable gasless web3 subscription processing
WEB3_SUBSCRIPTIONS_ENABLED=false

# ============================================================================
# PAYMENT CONFIGURATION
# ============================================================================
# Payment session expiry time
PAYMENT_EXPIRY_MINUTES=15

# Webhook settings
WEBHOOK_RETRY_LIMIT=3
WEBHOOK_TIMEOUT_SECONDS=10

# Price API (CoinGecko)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

# CORS - Add your frontend domains
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# Environment
ENVIRONMENT=development

# ============================================================================
# ADMIN ACCOUNT (Optional - for initial setup)
# ============================================================================
ADMIN_EMAIL=admin@dariforbusiness.com
ADMIN_PASSWORD=change-this-password-immediately

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=dari_payments.log

# ============================================================================
# PRODUCTION DEPLOYMENT (Render, Railway, Heroku, etc.)
# ============================================================================
# Set these in your deployment platform:
# - DATABASE_URL (PostgreSQL connection string)
# - JWT_SECRET (strong random string)
# - All RPC URLs with API keys
# - TRON_API_KEY
# - APP_BASE_URL (your production domain)
# - CORS_ORIGINS (your frontend domain)

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit the actual .env file to version control
# 2. Generate strong secrets: openssl rand -hex 32
# 3. Get Alchemy API keys: https://www.alchemy.com/
# 4. Get TronGrid API key: https://www.trongrid.io/
# 5. Get Google OAuth credentials: https://console.cloud.google.com/
#    - Create a new project
#    - Enable Google+ API
#    - Create OAuth 2.0 credentials
#    - Add authorized redirect URIs
# 6. Test with testnets before going live
# 7. Monitor gas prices and adjust confirmation requirements

